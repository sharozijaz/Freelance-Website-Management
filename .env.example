# Shared
NODE_ENV=development

# Apps
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3003
NEXT_PUBLIC_WEB_URL=http://localhost:3003

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agency_platform

# Authentication
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-me-with-at-least-32-random-characters
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:3000
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# One-time local bootstrap values. Set these in your shell; do not commit real credentials.
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-a-long-random-password
OWNER_NAME=Agency Owner
OWNER_ORGANIZATION_NAME=Agency Platform

# V1 legacy website rendering engine only
PAYLOAD_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3003
WEB_ORGANIZATION_ID=
WEB_WEBSITE_ID=
WEBSITE_PREVIEW_SECRET=replace-me-preview-secret
WEBSITE_REVALIDATION_SECRET=replace-me-revalidation-secret

# V1 legacy Payload CMS only
PAYLOAD_SECRET=replace-me
CMS_DEFAULT_ORGANIZATION_ID=
CMS_DEFAULT_WEBSITE_ID=
